{
    "manifest_version": 2,
    "name": "YouTube Utils",
	"description": "A Chrome extension that provides various utilities for YouTube, such as downloading videos, extracting audio, and ad blocking.",
    "version": "1.0 Beta",

    "permissions": ["storage", "tabs"],

    "icons": {
            "16": "images/image.png",
            "32": "images/image.png",
            "48": "images/image.png",
            "64": "images/image.png",
            "128": "images/image.png"
    },
	
	"browser_action": {			  			
			"default_title": "YouTube Utils",
			"default_icon":"images/image.png",
			"default_popup": "popup/popup.html"
	},

    "content_scripts" : [
        {
            "matches":["*://*.youtube.com/*"],
            "js":["content/content.js"],
            "run_at": "document_end"
        }
    ],
    
    "background": {
        "scripts": ["background/background.js"]
    }
    
}